PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/smartmeal
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
SPOONACULAR_API_KEY=your-spoonacular-api-key
SPOONACULAR_CACHE_TTL_MINUTES=720
CLIENT_URL=http://localhost:5173

# Backend email OTP. Required in production.
# For Gmail, use a Gmail App Password, not your normal account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=SmartMeal <your-email@gmail.com>

# Frontend
VITE_API_URL=http://localhost:5000/api
