PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/smartmeal
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
SPOONACULAR_API_KEY=your-spoonacular-api-key
SPOONACULAR_CACHE_TTL_MINUTES=720
CLIENT_URL=http://localhost:5173

# Optional. Required for real OTP email delivery in production.
# Without these, development mode prints OTP codes in the backend logs.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=SmartMeal <your-email@gmail.com>

# Alternative names also supported. Use either SMTP_* or EMAIL_*, not both.
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password
# EMAIL_FROM=SmartMeal <your-email@gmail.com>
